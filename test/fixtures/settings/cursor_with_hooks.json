{
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "_lockie_managed": true,
        "command": "lockie hook prompt"
      }
    ],
    "postToolUse": [
      {
        "_lockie_managed": true,
        "command": "lockie hook post-tool",
        "matcher": ".*"
      }
    ],
    "postToolUseFailure": [
      {
        "_lockie_managed": true,
        "command": "lockie hook post-tool",
        "matcher": ".*"
      }
    ],
    "preToolUse": [
      {
        "_lockie_managed": true,
        "command": "lockie hook pre-tool",
        "matcher": ".*"
      }
    ],
    "sessionEnd": [
      {
        "_lockie_managed": true,
        "command": "lockie hook session-stop"
      }
    ],
    "sessionStart": [
      {
        "_lockie_managed": true,
        "command": "lockie hook session-start"
      }
    ]
  },
  "version": 1
}
