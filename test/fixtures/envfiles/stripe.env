# Stripe-shaped values for detector tests are NOT committed (git push
# secret scanning rejects realistic key material). Before running
# TestEngine_StripeEnv, paste sample Stripe test keys here, e.g.:
#   STRIPE_SECRET_KEY=sk_test_…
#   STRIPE_PUBLISHABLE_KEY=pk_test_…
#   STRIPE_RESTRICTED_KEY=rk_test_…
# Use test-mode keys only; never commit live (sk_live_) keys.
STRIPE_SECRET_KEY=SAMPLE_STRIPE_SECRET_KEY_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=SAMPLE_STRIPE_PUBLISHABLE_KEY_REPLACE_ME
STRIPE_RESTRICTED_KEY=SAMPLE_STRIPE_RESTRICTED_KEY_REPLACE_ME
