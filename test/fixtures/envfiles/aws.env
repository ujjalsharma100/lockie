# AWS-shaped values for detector tests are NOT committed. Before running
# TestEngine_AWSEnv, paste sample documentation-style credentials here, e.g.:
#   AWS_ACCESS_KEY_ID=AKIA… (16 chars after prefix)
#   AWS_SECRET_ACCESS_KEY=<high-entropy secret on same line as SECRET keyword>
# See https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html
AWS_ACCESS_KEY_ID=SAMPLE_AWS_ACCESS_KEY_ID_REPLACE_ME
AWS_SECRET_ACCESS_KEY=SAMPLE_AWS_SECRET_ACCESS_KEY_REPLACE_ME
AWS_DEFAULT_REGION=us-east-1
