# Copy this file to test/.env and replace every placeholder with a fabricated,
# doc-shaped sample key (Stripe/AWS/jwt.io public examples — not live credentials).
# test/.env is gitignored and is the single source of truth for all tests.
#
#   cp test/.env.example test/.env
#
# Override path: LOCKIE_TEST_ENV=/path/to/secrets.env

STRIPE_SECRET_KEY=<sk_test_ key, 24+ chars after sk_test_>
STRIPE_PUBLISHABLE_KEY=<pk_test_ key>
STRIPE_RESTRICTED_KEY=<rk_test_ key>
AWS_ACCESS_KEY_ID=<AKIA + 16 uppercase alphanumeric>
AWS_SECRET_ACCESS_KEY=<40-char base64-ish secret, e.g. AWS docs wJalr…EXAMPLEKEY>
GITHUB_TOKEN=<ghp_ + 36 alphanumeric>
SLACK_BOT_TOKEN=<xoxb-…>
ANTHROPIC_API_KEY=<sk-ant-api03- + 40+ chars>
GOOGLE_API_KEY=<AIza + exactly 35 chars>
JWT=<eyJ….eyJ….. three-part JWT>
INTERNAL_API_TOKEN=<20+ char high-entropy token>
